# =================================================================
# .env para producción en InfinityFree
# Renombra a ".env" antes de subir. Reemplaza los valores marcados.
# =================================================================

APP_NAME="Revista Digital"
APP_ENV=production
APP_KEY=                              # Genera uno con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://revista-app.infinityfreeapp.com
APP_FORCE_HTTPS=true

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=warning

# --- Base de datos MySQL de InfinityFree ---
# Estos datos los obtienes en cPanel → MySQL Databases tras crear la BD
DB_CONNECTION=mysql
DB_HOST=sqlXXX.infinityfree.com       # ← reemplaza (algo como sql105.infinityfree.com)
DB_PORT=3306
DB_DATABASE=if0_XXXXXXXX_revista      # ← reemplaza
DB_USERNAME=if0_XXXXXXXX              # ← reemplaza (mismo prefijo del nombre de DB)
DB_PASSWORD=                          # ← reemplaza (la que pusiste al crear la DB)

# --- Sesión / cache en archivo (no en DB) para reducir queries ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
